From 235f3d2496ed6319e9907fa3b4872f4e8031cf3f Mon Sep 17 00:00:00 2001
From: SQLite-Enhance Builder <build@sqlite-enhance.local>
Date: Tue, 10 Mar 2026 05:55:52 +0000
Subject: [PATCH] Stage 1: Add lockfree writer queue

---
 sqlite3.c | 33 +++++++++++++++++++++++++++++++--
 1 file changed, 31 insertions(+), 2 deletions(-)

diff --git a/sqlite3.c b/sqlite3.c
index 8f9309a..99cd02a 100644
--- a/sqlite3.c
+++ b/sqlite3.c
@@ -68000,6 +68000,35 @@ typedef struct WalWriter {
 ** first write the part before iSyncPoint, then sync, then write the
 ** rest.
 */
+
+/* SQLite-Enhance: 无锁写入队列 */
+#include "enhance/lockfree_writer.h"
+
+static LockFreeWriter *g_lockfree_writer = NULL;
+static int g_lfw_initialized = 0;
+
+typedef struct WalWriter WalWriter;
+static int walWriteToLog(WalWriter*, void*, int, sqlite3_int64);
+
+static int walWriteToLogQueued(
+  WalWriter *p,
+  void *pContent,
+  int iAmt,
+  sqlite3_int64 iOffset
+){
+  if (!g_lfw_initialized || !g_lockfree_writer) {
+    return walWriteToLog(p, pContent, iAmt, iOffset);
+  }
+
+  // Set fd properly on first hit from the active WAL file struct
+  if (g_lockfree_writer->wal_fd == -1 && p && p->pFd) {
+    unixFile *pFile = (unixFile*)p->pFd;
+    g_lockfree_writer->wal_fd = pFile->h;
+  }
+
+  return lfw_submit(g_lockfree_writer, iOffset, pContent, iAmt);
+}
+
 static int walWriteToLog(
   WalWriter *p,              /* WAL to write to */
   void *pContent,            /* Content to be written */
@@ -68036,10 +68065,10 @@ static int walWriteOneFrame(
   u8 aFrame[WAL_FRAME_HDRSIZE];   /* Buffer to assemble frame-header in */
   pData = pPage->pData;
   walEncodeFrame(p->pWal, pPage->pgno, nTruncate, pData, aFrame);
-  rc = walWriteToLog(p, aFrame, sizeof(aFrame), iOffset);
+  rc = walWriteToLogQueued(p, aFrame, sizeof(aFrame), iOffset);
   if( rc ) return rc;
   /* Write the page data */
-  rc = walWriteToLog(p, pData, p->szPage, iOffset+sizeof(aFrame));
+  rc = walWriteToLogQueued(p, pData, p->szPage, iOffset+sizeof(aFrame));
   return rc;
 }

