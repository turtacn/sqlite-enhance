From 2383019f3168ee13e22a7566a830f65b37a258bf Mon Sep 17 00:00:00 2001
From: SQLite-Enhance Builder <build@sqlite-enhance.local>
Date: Wed, 11 Mar 2026 06:47:14 +0000
Subject: [PATCH] Stage 3: Add async I/O

---
 sqlite3.c | 18 ++++++++++++++++++
 1 file changed, 18 insertions(+)

diff --git a/sqlite3.c b/sqlite3.c
index 4261f09..182bf42 100644
--- a/sqlite3.c
+++ b/sqlite3.c
@@ -41159,12 +41159,18 @@ static int seekAndRead(unixFile *id, sqlite3_int64 offset, void *pBuf, int cnt){
 ** bytes were read successfully and SQLITE_IOERR if anything goes
 ** wrong.
 */
+#include "enhance/async_io.h"
+extern AsyncIOManager *g_async_io;
+
 static int unixRead(
   sqlite3_file *id,
   void *pBuf,
   int amt,
   sqlite3_int64 offset
 ){
+  if (g_async_io && g_async_io->fd != -1 && ((unixFile*)id)->h == g_async_io->fd) {
+    if (async_io_read_intercept(g_async_io, offset, pBuf, amt)) return SQLITE_OK;
+  }
   unixFile *pFile = (unixFile *)id;
   int got;
   assert( id );
@@ -41296,6 +41302,10 @@ static int unixWrite(
   int amt,
   sqlite3_int64 offset
 ){
+  if (g_async_io && g_async_io->fd != -1 && ((unixFile*)id)->h == g_async_io->fd) {
+    async_io_mark_dirty(g_async_io, offset, (void*)pBuf, amt);
+    return SQLITE_OK;
+  }
   unixFile *pFile = (unixFile*)id;
   int wrote = 0;
   assert( id );
@@ -41559,6 +41569,14 @@ static int openDirectory(const char *zFilename, int *pFd){
 ** will not roll back - possibly leading to database corruption.
 */
 static int unixSync(sqlite3_file *id, int flags){
+  if (!g_async_io) {
+    return full_fsync(((unixFile*)id)->h, flags, 0);
+  }
+  if (g_async_io->fd == -1) g_async_io->fd = ((unixFile*)id)->h;
+  async_io_flush_sync(g_async_io);
+  if (flags != SQLITE_SYNC_FULL) {
+    return SQLITE_OK;
+  }
   int rc;
   unixFile *pFile = (unixFile*)id;

--
